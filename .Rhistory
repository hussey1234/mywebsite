)
View(stock_price_df)
View(stock_price_long)
stock_summary <- stock_price_df %>%
summarise(
AAPL_mean = mean(AAPL),
TSLA_mean = mean(TSLA),
GSPC_mean = mean(GSPC),
AAPL_sd = sd(AAPL),
TSLA_sd = sd(TSLA),
GSPC_sd = sd(GSPC),
