TSLA_CV = TSLA_sd / TSLA_mean,
GSPC_CV = GSPC_sd / GSPC_mean
)
stock_summary
library(tidyverse)
library(ggplot2)
library(dplyr)
stock_price_df <- data.frame(
Month = month.abb,
AAPL = c(146.40, 164.02, 168.78, 176.31, 193.21, 195.68, 187.13, 170.77, 170.33, 189.46, 192.28, 184.16),
TSLA = c(205.17, 207.46, 164.31, 203.93, 261.77, 267.43, 258.08, 250.22, 200.81, 240.08, 248.48, 187.29),
GSPC = c(4373.94, 4530.41, 4131.93, 4132.15, 3785.38, 4130.29, 3955, 3585.62, 3871.98, 4080.11, 3839.50, 4076.60)
)
stock_price_df
stock_price_long <- stock_price_df %>%
pivot_longer(AAPL:GSPC, names_to = "Ticker", values_to = "Price")
head(stock_price_long)
stock_price_long %>%
mutate(Month = factor(Month, levels = month.abb))
ggplot(stock_price_long,
aes(x = Month,y = Price, color = Ticker, group = Ticker)) +
geom_line() + geom_point() +
labs(title = "Monthly Prices",
x = "Month",
y = "Price")
print("I would say that GSPC has the highest volatility because it has the biggest changes when the price goes up or down compared to TSLA and AAPL.")
stock_summary <- stock_price_df %>%
summarise(
AAPL_mean = mean(AAPL),
TSLA_mean = mean(TSLA),
GSPC_mean = mean(GSPC),
AAPL_sd = sd(AAPL),
TSLA_sd = sd(TSLA),
GSPC_sd = sd(GSPC),
AAPL_CV = AAPL_sd / AAPL_mean,
TSLA_CV = TSLA_sd / TSLA_mean,
GSPC_CV = GSPC_sd / GSPC_mean
)
stock_summary
print("You can see that TSLA has a much higher CV of 0.15 compared to GSPC with 0.06. This means that there is much more volatility in the data set relative to the mean.")
# monthly returns
returns_df <- stock_price_df %>%
mutate(
AAPL_ret = (AAPL - lag(AAPL)) / lag(AAPL),
TSLA_ret = (TSLA - lag(TSLA)) / lag(TSLA)
)
returns_df
print("")
returns_df %>%
select(Month, AAPL_ret, TSLA_ret) %>%
pivot_longer(c(AAPL_ret, TSLA_ret),
names_to = "Ticker", values_to = "Return") %>%
ggplot(aes(Month, Return, color = Ticker)) +
geom_line() +
labs(title="Monthly Returns: AAPL vs TSLA")
returns_df$Month <- factor(returns_df$Month, levels = month.abb)
ggplot(returns_df %>% pivot_longer(AAPL_ret:TSLA_ret,
names_to="Ticker", values_to="Return"),
aes(Month, Return, color=Ticker, group=Ticker)) +
geom_line()
ggplot(
returns_df %>%
pivot_longer(c(AAPL_ret, TSLA_ret),
names_to="Ticker", values_to="Return"),
aes(Month, Return, color=Ticker, group=Ticker)
) +
geom_line()
ggplot(
returns_df %>%
pivot_longer(c(AAPL_ret, TSLA_ret),
names_to="Ticker", values_to="Return"),
aes(Month, Return, color=Ticker, group=Ticker)
) + geom_line()
redline <- read_csv("redline.csv") %>%
arrange(zip)
head(redline, 10)
redline_long <- redline %>%
select(zip, race, fire, theft, involact) %>%
pivot_longer(cols = c(race, fire, theft, involact),
names_to = "Variable",
values_to = "Value")
head(redline_long)
ggplot(redline_long, aes(x = Variable, y = Value)) +
geom_boxplot() +
facet_wrap(~ Variable, scales = "free")
View(redline)
redline %>%
mutate(Minority_Group = if_else(race > 50, "High Minority", "Low Minority"),
fire_q = cut_number(fire, 4))   # quartiles
ggplot(redline, aes(x = Minority_Group, y = involact)) +
stat_summary(fun = mean, geom = "bar") +
facet_wrap(~fire_q)
ggplot(redline, aes(x = Minority_Group, y = involact)) +
stat_summary(fun = mean, geom = "bar") +
facet_wrap(~fire_q)
ggplot(redline, aes(x = Minority_Group, y = involact)) +
stat_summary(fun = mean, geom = "bar") +
facet_wrap(~ fire_q)
