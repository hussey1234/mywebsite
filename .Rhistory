group_by(Ticker) %>%
summarise(
mean_price = mean(Price),
sd_price   = sd(Price),
CV         = sd_price / mean_price
)
stock_summary <- stock_price_df %>%
summarise(
mean_price = mean(Price),
sd_price   = sd(Price),
