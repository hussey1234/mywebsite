plotdata <- subset(longdata2, name %in% c("bondRatio", "stockRatio")) %>%
group_by(YEAR, COMPANY_TYPE_DESC, name) %>%
summarise(value = mean(value, na.rm = TRUE), .groups = "drop")
ggplot(plotdata, aes(x = YEAR, y = value, fill = name)) +
geom_col() +
facet_wrap(~ COMPANY_TYPE_DESC) +
coord_cartesian(ylim = c(0, 1)) +
theme(axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "bottom") +
labs(title = "Average Bond vs Stock Ratios Over Time",
x = "Year", y = "Average Ratio")
